<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="16dp"
        android:gravity="center">

        <!-- Кнопка 1: Вызов браузера -->
        <Button
            android:id="@+id/btnOpenBrowser"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Открыть сайт МИРЭА"
            android:onClick="onOpenBrowser" />

        <!-- Кнопка 2: Передача ФИО в другое приложение -->
        <Button
            android:id="@+id/btnShare"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Поделиться моими данными"
            android:onClick="onShareData" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>